{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChemWorld recipe",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "ChemWorld event action",
        "type": "object",
        "required": ["operation"],
        "properties": {
          "operation": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "add_reagent",
                  "add_solvent",
                  "add_catalyst",
                  "heat",
                  "wait",
                  "sample",
                  "quench",
                  "add_phase",
                  "add_extractant",
                  "mix",
                  "settle",
                  "separate_phase",
                  "wash",
                  "dry",
                  "concentrate",
                  "transfer",
                  "terminate",
                  "measure"
                ]
              },
              {"type": "integer", "minimum": 0, "maximum": 17}
            ]
          },
          "payload": {"type": "object"},
          "instrument": {
            "oneOf": [
              {"type": "string", "enum": ["hplc", "gc", "uvvis", "final_assay"]},
              {"type": "integer", "minimum": 0, "maximum": 3}
            ]
          },
          "phase": {
            "oneOf": [
              {"type": "string", "enum": ["reactor_liquid", "aqueous", "organic"]},
              {"type": "integer", "minimum": 0, "maximum": 2}
            ]
          },
          "target_phase": {
            "oneOf": [
              {"type": "string", "enum": ["reactor_liquid", "aqueous", "organic"]},
              {"type": "integer", "minimum": 0, "maximum": 2}
            ]
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "metadata": {"type": "object"}
  },
  "additionalProperties": true
}
