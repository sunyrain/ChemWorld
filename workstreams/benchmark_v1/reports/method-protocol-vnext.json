  "interaction_failures": [
    {
      "consequence": "they do not test within-experiment control or spectral interpretation",
      "evidence": "formal classic methods update only between complete experiments",
      "failure_id": "recipe_only_classic_control",
      "remediation": "retain operation-level baselines and report capability strata separately",
      "severity": "high"
    },
    {
      "consequence": "safe optimization effectiveness is not identifiable",
      "evidence": "600 legacy formal runs contain zero threshold violations",
      "failure_id": "inactive_legacy_safety_threshold",
      "remediation": "rerun constrained methods with calibrated task-level operational-risk budgets",
      "severity": "critical"
    },
    {
      "consequence": "arbitrary material numbering induces false neighborhood structure",
      "evidence": "GP-PI, GP-UCB and RF-EI use scalar material coordinates",
      "failure_id": "ordinal_material_encoding",
      "remediation": "add typed categorical encodings before formal inclusion",
      "severity": "high"
    },
    {
      "consequence": "the pilot cannot establish that more experiments do or do not help",
      "evidence": "five-seed diagnostic reaches no statistical-plus-effect gate at any checkpoint",
      "failure_id": "pilot_budget_curve_underpowered",
      "remediation": "use the preregistered 20 paired confirmatory seeds and checkpoint estimands",
      "severity": "high"
    },
    {
      "consequence": "stub or replay performance cannot support an LLM claim",
      "evidence": "retained real-LLM artifact and verified trajectory counts are zero",
      "failure_id": "no_live_llm_evidence",
      "remediation": "freeze two live model adapters with full usage/provenance and replay verification",
      "severity": "critical"
    },
    {
      "consequence": "the benchmark exposes spectroscopy without measuring spectral reasoning value",
      "evidence": "raw and processed spectra reach the next decision but no formal policy consumes them",
      "failure_id": "spectra_information_without_policy_evidence",
      "remediation": "require spectra-enabled versus spectra-masked paired ablation",
      "severity": "critical"
    },
    {
      "consequence": "classic, RL and LLM results are not resource-comparable",
      "evidence": "legacy runner records experiment operations but not tokens, model calls, training steps or compute",
      "failure_id": "missing_cross_family_resource_ledger",
      "remediation": "enforce the cumulative method resource ledger for every official adapter",
      "severity": "critical"
    }
  ],
