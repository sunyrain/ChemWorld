{
  "schema_version": "chemworld-portable-release-protocol-0.1",
  "protocol_id": "foundation-v05-portable-release",
  "backend_id": "backend-v0.5-formal-candidate",
  "benchmark_claim_allowed": false,
  "required_platforms": [
    "linux",
    "windows"
  ],
  "semantic_sources": [
    "src/chemworld/action_codec.py",
    "src/chemworld/agent_interface.py",
    "src/chemworld/backends/**/*.py",
    "src/chemworld/envs/**/*.py",
    "src/chemworld/foundation/**/*.py",
    "src/chemworld/materials.py",
    "src/chemworld/operation_validator.py",
    "src/chemworld/physchem/**/*.py",
    "src/chemworld/registration.py",
    "src/chemworld/runtime/**/*.py",
    "src/chemworld/tasks.py",
    "src/chemworld/world/**/*.py",
    "src/chemworld/wrappers.py",
    "configs/mechanisms/**/*",
    "configs/scenarios/**/*",
    "configs/public_dev.json",
    "configs/public_test.json"
  ],
  "semantic_excludes": [
    "**/__pycache__/**",
    "**/*.pyc"
  ],
  "documentation_sources": [
    "README.md",
    "mkdocs.yml",
    "docs/**/*",
    "site/**/*"
  ],
  "required_evidence": {
    "backend": "workstreams/world_foundation/reports/backend-v0.5.json",
    "release_gates": "workstreams/world_foundation/reports/backend-v0.5-release-gates.json",
    "evidence_quarantine": "workstreams/benchmark_v1/reports/evidence-quarantine-v0.5.json",
    "contract_coherence": "workstreams/world_foundation/reports/contract-coherence-v0.5.json",
    "composed_runtime_stress": "workstreams/world_foundation/reports/composed-runtime-stress-v0.5.json",
    "observation_identifiability": "workstreams/world_foundation/reports/observation-identifiability-v0.5.json",
    "task_validity_power": "workstreams/world_foundation/reports/task-validity-power-v0.5.json"
  },
  "required_evidence_flags": {
    "backend": "backend_freeze_allowed",
    "release_gates": "success",
    "evidence_quarantine": "controls_ready",
    "contract_coherence": "controls_ready",
    "composed_runtime_stress": "controls_ready",
    "observation_identifiability": "controls_ready",
    "task_validity_power": "controls_ready"
  },
  "dependency_lock": "uv.lock",
  "golden_replay": "composed_runtime_stress",
  "numeric_tolerances": {
    "absolute": 1e-12,
    "relative": 1e-10
  }
}
