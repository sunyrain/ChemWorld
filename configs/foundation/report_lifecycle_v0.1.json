{
  "schema_version": "chemworld-report-lifecycle-policy-0.1",
  "report_glob": "workstreams/*/reports/**/*.json",
  "categories": [
    "current",
    "historical",
    "superseded",
    "external"
  ],
  "classification_order": [
    "archive_directory_as_historical",
    "explicit_superseded",
    "explicit_external",
    "current_evidence_dag_reference",
    "default_historical"
  ],
  "external_paths": [
    "workstreams/world_foundation/reports/backend-external-gates-v0.5.json"
  ],
  "superseded_paths": [
    "workstreams/flagship_tasks/reports/mechanism-adaptation-gate-a-v0.2.2.json"
  ],
  "default_noncurrent_category": "historical",
  "deletion_policy": "classification_never_authorizes_deletion",
  "current_surface_source": "configs/current.json#evidence_dag.nodes"
}
